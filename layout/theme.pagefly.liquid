    {% comment %} Third-party script deferral (homepage only).
         Intercepts appendChild/insertBefore for dynamically-created script elements
         from non-essential third-party domains. Scripts are NOT removed — they load
         after user interaction or 12s post-load, outside the critical TBT window.
         Estimated savings: ~2,000ms TBT from clarity (814ms), boost (726ms),
         PageFly gtag (620ms), Facebook (304ms), pop-convert (269ms), etc. {% endcomment %}
    {%- if request.page_type == 'index' -%}
    <script>
      (function(){
        var Q=[], R=false;
        var OA=Node.prototype.appendChild;
        var OI=Node.prototype.insertBefore;

        function D(n){
          if(R||!n||n.tagName!=='SCRIPT'||!n.src) return false;
          var s=n.src;
          return s.indexOf('clarity.ms')>-1||
                 s.indexOf('connect.facebook.net')>-1||
                 s.indexOf('pop-convert.com')>-1||
                 s.indexOf('one.store/javascript')>-1||
                 s.indexOf('powr.io')>-1||
                 s.indexOf('sharethis.com')>-1||
                 s.indexOf('uppromote')>-1||
                 s.indexOf('shareasale.com')>-1||
                 s.indexOf('boost-cdn-prod')>-1||
                 s.indexOf('pagefly.io/pagefly/core/analytics')>-1;
        }

        Node.prototype.appendChild=function(c){
          if(D(c)){Q.push(c);return c;}
          return OA.call(this,c);
        };
        Node.prototype.insertBefore=function(n,r){
          if(D(n)){Q.push(n);return n;}
          return OI.call(this,n,r);
        };

        function X(){
          if(R) return; R=true;
          Node.prototype.appendChild=OA;
          Node.prototype.insertBefore=OI;
          var i=0, ric='requestIdleCallback' in window;
          (function L(){
            if(i>=Q.length) return;
            function run(){try{OA.call(document.head,Q[i]);}catch(e){}i++;setTimeout(L,100);}
            ric ? requestIdleCallback(run,{timeout:3000}) : setTimeout(run,150);
          })();
        }

        ['scroll','click','touchstart','keydown','mousemove'].forEach(function(e){
          document.addEventListener(e,function h(){
            document.removeEventListener(e,h);setTimeout(X,0);
          },{once:true,passive:true});
        });
        window.addEventListener('load',function(){setTimeout(X,12000);});
      })();
    </script>
    {%- endif -%}

