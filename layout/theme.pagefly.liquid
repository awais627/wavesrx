    {% comment %} GTM & Hotjar deferred — loads on first user interaction OR 8s after load.
         Using requestIdleCallback(3s) caused TBT spike (3760ms) because the timeout fired
         while main thread was busy with Shopify scripts, dumping the entire GTM cascade
         (Clarity, Facebook, Google Ads, ShareThis) into the critical period.
         Interaction-based loading ensures analytics only start after the user engages. {% endcomment %}
    <script>
      window.dataLayer = window.dataLayer || [];
      window.hj = window.hj || function() { (window.hj.q = window.hj.q || []).push(arguments); };
      window._hjSettings = { hjid: 3833078, hjsv: 6 };

      function _loadGTM() {
        if (window._gtmLoaded) return;
        window._gtmLoaded = true;
        dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
        var j = document.createElement('script');
        j.async = true;
        j.src = 'https://www.googletagmanager.com/gtm.js?id=GTM-WW44S75X';
        document.head.appendChild(j);
        var r = document.createElement('script');
        r.async = true;
        r.src = 'https://static.hotjar.com/c/hotjar-3833078.js?sv=6';
        document.head.appendChild(r);
      }

      var _evts = ['scroll', 'click', 'touchstart', 'keydown'];
      function _onInteract() {
        _evts.forEach(function(e) { document.removeEventListener(e, _onInteract); });
        setTimeout(_loadGTM, 0);
      }
      _evts.forEach(function(e) { document.addEventListener(e, _onInteract, { once: true, passive: true }); });
      {% comment %} Homepage gets longer fallback (12s) to keep GTM/Hotjar/Clarity cascade
           off the critical path on slow mobile devices. Other pages keep 8s. {% endcomment %}
      window.addEventListener('load', function() { setTimeout(_loadGTM, {% if request.page_type == 'index' %}12000{% else %}8000{% endif %}); });
    </script>
