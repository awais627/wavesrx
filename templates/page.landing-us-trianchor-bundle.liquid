<section class="bundle-section">
  <div class="container">
    <h2 class="section-title">FREQUENTLY BOUGHT TOGETHER</h2>

    <form id="bundle-form">
      <div class="bundle-items">

        {% assign products = 
          bundle_product_1 | append: ',' | 
          append: bundle_product_2 | append: ',' | 
          append: bundle_product_3 
        %}

        {% for product in products %}
          {% assign variant = product.first_available_variant %}
          <div class="bundle-item">
            <label>
              <input 
                type="checkbox"
                class="bundle-checkbox"
                data-price="{{ variant.price | divided_by: 100.0 }}"
                value="{{ variant.id }}"
                checked
              >
              <img src="{{ product.featured_image | image_url: '200x' }}" height="200px" width="200px">
              <div class="bundle-info">
                <h4>{{ product.title }}</h4>
                <p>{{ variant.price | money }}</p>
              </div>
            </label>
          </div>
        {% endfor %}

      </div>

      <div class="bundle-summary">
        <p>Total Price: <strong id="bundle-total"></strong></p>
        <button type="button" id="bundle-add" class="btn-yellow">
          BUNDLE & SAVE
        </button>
      </div>
    </form>
  </div>
</section>
<script>
  document.addEventListener("DOMContentLoaded", function() {

    const checkboxes = document.querySelectorAll(".bundle-checkbox");
    const totalEl = document.getElementById("bundle-total");
    const addBtn = document.getElementById("bundle-add");

    const discountPercent = 15; // change bundle discount %

    function updateTotal() {
      let total = 0;

      checkboxes.forEach(cb => {
        if (cb.checked) {
          total += parseFloat(cb.dataset.price);
        }
      });

      let discounted = total - (total * discountPercent / 100);

      totalEl.innerHTML = 
        "$" + discounted.toFixed(2) + 
        ` <span style="text-decoration:line-through;color:#999;font-size:16px;">$${total.toFixed(2)}</span>`;
    }

    updateTotal();

    checkboxes.forEach(cb => cb.addEventListener("change", updateTotal));

    addBtn.addEventListener("click", function() {

      let items = [];

      checkboxes.forEach(cb => {
        if (cb.checked) {
          items.push({
            id: cb.value,
            quantity: 1
          });
        }
      });

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: items })
      })
      .then(response => response.json())
      .then(() => {
        window.location.href = '/cart';
      });

    });

  });
</script> {% endcomment %}

