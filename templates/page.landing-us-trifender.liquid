<style>
    .hero-landing {
      padding: 22px 20px 50px;
      background: #EEEEEE;
    }

    .hero-header {
      text-align: center;
      margin-bottom: 22px;
    }

    .hero-header h1 {
      font-size: 36px;
      font-weight: 900;
      margin-bottom: 12px;
      line-height: 1.2;
    }

    .hero-header p {
      font-size: 18px;
      color: #555;
      font-weight: 600;
    }

    /* Banner */
    .hero-banner {
      display: flex;
      flex-wrap: wrap;
      gap: 40px;
      align-items: flex-start;
      max-width: 1300px;
      margin: auto;
    }

    /* Left video */
    .hero-left {
      flex: 1;
      min-width: 300px;
    }

    .hero-left iframe,
    .hero-video {
      width: 100%;
      height: 400px;
      border-radius: 14px;
    }

    /* Right info */
    .hero-right {
      flex: 1;
      min-width: 300px;
      position: relative;
    }

    .hero-right h2 {
      font-size: 28px;
      font-weight: 900;
      margin-bottom: 16px;
      line-height: 1.2;
    }

    .hero-right ul {
      margin-bottom: 20px;
      padding-left: 24px;
      font-weight: 600;
      list-style-type: disc;
      list-style-position: outside;
    }

    .hero-right ul li {
      margin: 8px 0;
      line-height: 1.4;
    }

    /* Price */
    .hero-price {
      font-size: 22px;
      font-weight: 700;
      margin-bottom: 16px;
      line-height: 1.2;
    }

    .sale-price {
      color: #e60023;
      margin-right: 10px;
    }

    .compare-price {
      text-decoration: line-through;
      color: #999;
    }

    /* Buttons */
    .hero-buy-btn,
    .hero-right .btn-yellow,
    .hero-right .btn-outline {
      text-align: center;
      box-sizing: border-box;
      display: inline-block;
      font-weight: 700;
      border-radius: 100px;
      padding: 14px 26px;
      text-decoration: none;
      cursor: pointer;
      transition: 0.2s;
    }

    .hero-buy-btn,
    .hero-right .btn-yellow {
      background: #ffb800;
      color: #000;
    }

    .hero-buy-btn:hover,
    .hero-right .btn-yellow:hover {
      background: #ffc933;
    }

    .hero-right .btn-outline {
      background: #fff;
      border: 1px solid #e6e6e6;
      color: #000;
    }

    .hero-right .btn-outline:hover {
      background: #000;
      color: #fff;
    }

    .hero-right .btn-yellow {
      margin-right: 7px;
    }

    .hero-right .btn-outline {
      margin-left: 7px;
    }

    /* Reviews */
    .rating-wrapper {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 14px;
      font-weight: 600;
    }

    .stars-outer {
      position: relative;
      display: inline-block;
      color: #ddd;
      overflow: hidden;
      width: 90px;
      white-space: nowrap;
      font-size: 20px;
    }

    .stars-outer::before{
      content: "★★★★★";
    }

    .stars-inner::before {
      content: "★★★★★";
    }

    .stars-inner {
    position: absolute;
    top: 0;
    left: 0;
    white-space: nowrap;
    overflow: hidden;
    width: calc(var(--rating) * 20%); /* Correct width calculation */
    color: #f5a623;
  }

    .rating-link:hover .stars-inner {
      filter: brightness(1.1);
    }

    .rating-link:hover .reviews {
      color: #ffc933;
      font-weight: bold;
    }

    /* Sale badge */
    .sale-percentage {
      background: #ff4d4f;
      color: #fff;
      font-size: 12px;
      font-weight: 700;
      padding: 6px 10px;
      border-radius: 14px;
      display: none;
    }

    /* Responsive adjustments */
    @media (max-width: 992px) {
      .hero-banner {
        gap: 30px;
      }
    }

    @media (max-width: 768px) {
      .hero-banner {
        flex-direction: column;
        gap: 25px;
      }

      .hero-left,
      .hero-right {
        flex: 1 1 100% !important;
        min-width: 100% !important;
      }

      .hero-left iframe,
      .hero-video {
        height: 300px;
      }

      .hero-header h1 {
        font-size: 28px;
      }

      .hero-header p {
        font-size: 16px;
      }

      .hero-right h2 {
        font-size: 24px;
      }

      .hero-right ul {
        padding-left: 20px;
      }

      .hero-price {
        font-size: 20px;
      }

      /* Stack buttons on mobile */
      .hero-right form,
      .hero-right .btn-outline {
        width: 100%;
      }

      .hero-right .btn-yellow {
        width: 100%;
      }

      .hero-right div[style*="display:flex"] {
        flex-direction: column;
        gap: 12px;
      }

      /* Sale badge smaller and moved */
      .sale-percentage {
        font-size: 11px;
        padding: 5px 8px;
      }
    }

    @media (max-width: 480px) {
      .hero-header h1 {
        font-size: 22px;
      }

      .hero-header p {
        font-size: 14px;
      }

      .hero-right h2 {
        font-size: 20px;
      }

      .hero-price {
        font-size: 18px;
      }

      .hero-left iframe,
      .hero-video {
        height: 220px;
      }
    }
</style>
<section class="hero-landing">
  <!-- Heclasseader -->
  <div class="hero-header" style="text-align:center; margin-bottom:25px;">
    <h1 style="font-size:36px; font-weight:900; margin-bottom:12px; line-height:1.15;">
      Premium Gear <br class="mobile-break">
      for Boats &amp; PWC
    </h1>

    <style>
      .mobile-break { display: none; }
      @media (max-width: 749px){
        .mobile-break { display: block; }
      }
    </style>
    <p style="font-size:18px; color:#555; font-weight:600;">Amazon Top-Rated Marine Products</p>
  </div>

  <div
    class="hero-banner"
    style="display:flex; flex-wrap:wrap; gap:40px; align-items:center; max-width:1300px; margin:auto;"
  >
    <!-- LEFT: Video -->
    <div class="hero-left" style="flex:1; min-width:300px;">
      {% if main_product.metafields.custom.ads_short_video %}
        {% assign video_url = main_product.metafields.custom.ads_short_video %}
        {% if video_url contains '?' %}
          {% assign joiner = '&' %}
        {% else %}
          {% assign joiner = '?' %}
        {% endif %}

        <iframe
          src="{{ video_url }}{{ joiner }}playsinline=1&controls=1&rel=0"
          frameborder="0"
          allow="autoplay; encrypted-media; fullscreen; picture-in-picture"
          allowfullscreen
          style="width:100%; height:400px; border-radius:14px;"
        ></iframe>
      {% endif %}
    </div>

    <!-- RIGHT: Info -->
    <div class="hero-right" style="flex:1; min-width:300px; position:relative;">
      <!-- Reviews -->
      {% assign r = main_product.metafields.custom.rating_count | default: 0 %}
      {% assign rc = main_product.metafields.custom.review_count | default: 0 %}

      {% if r > 0 %}
        <div style="margin-bottom:20px; font-size:16px; font-weight:600;">
          <a
            href="{{ hero_url }}"
            class="rating-link"
            style="text-decoration:none; color:inherit; display:inline-block;"
          >
            <div class="rating-wrapper">
              <div class="stars" style="color: #ffb400;">★★★★★</div>
              <span class="reviews">({{ rc }}) reviews</span>
            </div>
          </a>
        </div>
      {% endif %}

      <!-- Title -->
      <h2 style="font-size:28px; font-weight:900; margin-bottom:6px;">
        <a href="https://www.wavesrx.com/products/wrx_pwctf_2pk">TRIFENDER PWC DOCKING BUMPERS</a>
      </h2>

      <!-- Sub Title -->
      <p style="margin:0 0 16px; font-size:20px; font-weight:600; opacity:0.85;">
        Maximum Protection. Minimal Storage.
      </p>

      <!-- Features -->
      {% if main_product.metafields.custom.ads_features_list %}
        {% assign features = main_product.metafields.custom.ads_features_list.value %}
        {% if features and features.size > 0 %}
          <ul style="margin-bottom:20px; padding-left:24px; font-weight:600; list-style-type:disc; list-style-position:outside;">
            {% for feature in features %}
              <li style="display:list-item; list-style-type:disc; margin:8px 0;">
                {{ feature }}
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      {% endif %}
      <!-- Price -->
      <p style="font-size:22px; font-weight:700; margin-bottom:16px; display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
        {% if hero_compare_price > hero_price %}
          <span style="color:#e60023;">
            {{ hero_price | money }}
          </span>

          <span style="text-decoration:line-through; color:#999; font-size:16px;">
            {{ hero_compare_price | money }}
          </span>

          <!-- SAVE badge (moved here) -->
          <span
            class="sale-percentage"
            data-sale-price="{{ hero_price | divided_by: 100.0 }}"
            data-sale-old-price="{{ hero_compare_price | divided_by: 100.0 }}"
            style="
              background:#ff4d4f;
              color:#fff;
              font-size:12px;
              font-weight:700;
              padding:6px 10px;
              border-radius:14px;
              display:none;
              line-height:1;
            "
          >
            SAVE
          </span>

          <script>
            document.querySelectorAll('.sale-percentage').forEach((badge) => {
              const p = parseFloat(badge.dataset.salePrice);
              const o = parseFloat(badge.dataset.saleOldPrice);
              if (o > p) {
                badge.textContent = `SAVE ${Math.round(((o - p) / o) * 100)}%`;
                badge.style.display = 'inline-block';
              }
            });
          </script>
        {% else %}
          <span>{{ hero_price | money }}</span>
        {% endif %}
      </p>

      <!-- Buttons -->
      <div style="display:flex; gap:14px; flex-wrap:wrap;">
        <form method="post" action="/cart/add">
          <input type="hidden" name="id" value="{{ hero_cart_id }}">
          <button type="submit" class="btn-yellow">BUY NOW</button>
        </form>

        <a href="{{ hero_url }}" class="btn-outline"> LEARN MORE </a>
      </div>
    </div>
  </div>
</section>

