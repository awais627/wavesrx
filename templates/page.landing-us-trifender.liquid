                <a class="btn-outline" href="{{ product.url }}">Learn More</a>
              </div>
            </div>
          </div>
        </article>
      {%- endfor -%}
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', function () {
        const step = 4;
        const container = document.querySelector('#new-arrivals');
        if (!container) return;

        const button = container.querySelector('#load-more-new-arrivals');
        if (!button) return;

        function updateButton() {
          const hiddenCount = container.querySelectorAll('.new-arrivals-grid .product-card.is-hidden').length;
          button.style.display = hiddenCount > 0 ? 'inline-block' : 'none';
        }

        button.addEventListener('click', () => {
          const hiddenCards = container.querySelectorAll('.new-arrivals-grid .product-card.is-hidden');
          const revealCount = Math.min(step, hiddenCards.length);
          for (let i = 0; i < revealCount; i++) {
            hiddenCards[i].classList.remove('is-hidden');
          }
          updateButton();
        });

        updateButton();
      });
    </script>
  </div>
</section>

