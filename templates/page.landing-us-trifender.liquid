{% assign best_sellers = collections['best-selling'] %}
{% assign new_arrivals = collections['new-arrivals'] %}
{% assign main_product = all_products.wrx_pwctf_2pk %}
{% assign variant_id = main_product.metafields.custom.hero_variant_id %}

{% if variant_id %}
  {% assign featured_variant = main_product.variants | where: 'id', variant_id | first %}
{% endif %}

{% if featured_variant %}
  {% assign hero_variant = featured_variant %}
{% else %}
  {% assign hero_variant = main_product.first_available_variant %}
{% endif %}

{% assign hero_price = hero_variant.price %}
{% assign hero_compare_price = hero_variant.compare_at_price %}
{% assign hero_cart_id = hero_variant.id %}
{% assign hero_url = main_product.url | append: '?variant=' | append: hero_variant.id %}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@700;800;900&display=swap" rel="stylesheet">
