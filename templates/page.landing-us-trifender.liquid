<script>
  (function () {
    const script = document.createElement('script');
    script.src = 'https://cdn.appio.so/v1/appio.js';
    script.async = true;

    script.onload = function () {
      if (window.Appio && typeof Appio.loadBadges === 'function') {
        Appio.loadBadges();
      }
    };

    document.head.appendChild(script);
  })();

  window.getPercentage = function (oldPrice, price) {
    if (typeof oldPrice !== 'number' || typeof price !== 'number' || oldPrice <= 0 || oldPrice <= price) {
      return { valid: false, value: 0 };
    }
    const percentageDifference = Math.round(((oldPrice - price) / oldPrice) * 100);
    return { valid: true, value: percentageDifference };
  };

  // Auto-update all badges on page
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('[data-sale-price]').forEach((badge) => {
      const price = parseFloat(badge.dataset.salePrice);
      const oldPrice = parseFloat(badge.dataset.saleOldPrice);
      const discount = getPercentage(oldPrice, price);

      if (discount.valid) {
        badge.textContent = `Save ${discount.value}%`;
        badge.style.display = 'inline-block';
      } else {
        badge.style.display = 'none';
      }
    });
  });
</script>
