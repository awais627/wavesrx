<style>
  .reviews-section {
    padding: 50px 20px;
    text-align: center;
  }

  .reviews-wrap {
    max-width: 1240px;
    margin: auto;
    display: flex;
    flex-direction: column; /* stack badge + slider */
    gap: 30px;
    align-items: center;
  }

  /* Badge */
  .reviews-badge {
    background: transparent;
    color: #111;
    padding: 20px;
    font-weight: 900;
    line-height: 1.2;
  }

  .reviews-badge .rating {
    font-size: 1.125rem; /* 18px */
    margin-bottom: 10px;
  }

  .reviews-badge h3 {
    font-size: 1.875rem; /* 30px */
    font-weight: bold;
  }

  /* Slider */
  .reviews-container {
    width: 100%;
    overflow: hidden;
  }

  .reviews-slider {
    width: 100%;
  }

  .reviews-track {
    display: flex;
    transition: transform 0.35s ease;
  }

  /* Review card */
  .review {
    min-width: 100%;
    background: #e9e9e9;
    padding: 20px;
    border-radius: 12px;
    box-sizing: border-box;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-align: center;
  }

  /* 1st row: Flag | Name | Date | Verified */
  .review .review-header {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    font-size: 0.875rem;
    justify-content: center;
  }

  .review .review-header img.flag {
    width: 20px;
    height: 14px;
    object-fit: cover;
    border-radius: 2px;
  }

  .review .verified-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.75rem; /* 12px */
    font-weight: 600;
    color: #1da1f2;
  }

  .review .verified-icon {
    flex-shrink: 0;
  }

  /* 2nd row: stars */
  .review .stars {
    color: #ffb400;
    font-size: 1.125rem; /* 18px */
  }

  /* 3rd row: review title */
  .review h4 {
    font-size: 1rem; /* 16px */
    font-weight: 900;
    margin: 0;
    letter-spacing: normal;
  }

  /* Review content */
  .review p {
    font-size: 18px;
    color: #444;
    line-height: 1.5;
    margin: 0;
  }

  /* Product title */
  .review .product-title {
    font-size: 0.875rem; /* 14px */
