</a>
            <!-- END SPT.WISHLIST -->

    <a class="custom-header-email" href="mailto:{{ section.settings.footer_email }}" aria-label="Email Us">{{ section.settings.header_email_text }} {{ section.settings.footer_email }}</a>
  </div>
</div>
