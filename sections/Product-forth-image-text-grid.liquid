<div class="container image-grid">
    <div class="row">
        <div class="col order-text">
            <div class="content-box">
                <h2 class="product-page-heading">{{ product.metafields.custom.product_forth_image_text_grid_heading }}</h2>
                <p class="product-page-description">{{ product.metafields.custom.product_forth_image_text_grid_description }}</p>
            </div>
        </div>
        <div class="col">
            <div class="img-box">
                {% if product.metafields.custom.product_fotrh_image_text_grid_image != blank -%}
                    <img src="{{ product.metafields.custom.product_fotrh_image_text_grid_image | file_url }}" width="600" height="400" loading="lazy" alt="{{ product.title | escape }}">
                {%- endif %}
            </div>
        </div>
    </div>
</div>
{% schema %}
{
    "name": "Second-image-text-grid",
    "settings": [ ],
    "presets": [
        {
            "name": "Product-Forth-image-text-grid"
        }
    ]
}
{% endschema %}
