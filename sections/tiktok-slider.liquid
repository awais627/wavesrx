<script>
document.addEventListener('DOMContentLoaded', function() {
    var mySwiper = new Swiper('.swiper-container', {
        slidesPerView: 5,
        spaceBetween: 0,
        initialSlide: 5,
        watchOverflow: true,
        centeredSlides: true,
        loop: true,
        breakpoints: {
            1100: {
                slidesPerView: 5,
                spaceBetween: 0,
            },
            768: {
                slidesPerView: 1,
                spaceBetween: 0,
            },
            250: {
                slidesPerView: 1,
                spaceBetween: 50,
            },
        },
        navigation: {
            nextEl: '.swiper-button-next_1',
            prevEl: '.swiper-button-prev_1',
        },
    });

    function loadAndPlayAll() {
        var videos = document.querySelectorAll('.swiper-slide video');
        videos.forEach(function(video) {
            video.preload = 'auto';
            video.load();
            var p = video.play();
            if (p !== undefined) {
                p.catch(function() {
                    video.addEventListener('canplay', function handler() {
                        video.play();
                        video.removeEventListener('canplay', handler);
                    });
                });
            }
        });
        var activeVideo = document.querySelector('.swiper-slide.swiper-slide-active video');
        if (activeVideo) {
            activeVideo.parentElement.classList.add('active-slide');
        }
    }

    mySwiper.on('transitionEnd', function () {
        var videos = document.querySelectorAll('.swiper-slide video');
        videos.forEach(function(video) {
            video.parentElement.classList.remove('active-slide');
        });
        var activeVideo = document.querySelector('.swiper-slide.swiper-slide-active video');
        if (activeVideo) {
            activeVideo.parentElement.classList.add('active-slide');
        }
    });

    // Lazy-load: only start all videos when slider section is visible
    if ('IntersectionObserver' in window) {
        var swiperEl = document.querySelector('.swiper-container');
        var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                if (entry.isIntersecting) {
                    loadAndPlayAll();
                    observer.disconnect();
                }
            });
        }, { threshold: 0.1 });
        if (swiperEl) observer.observe(swiperEl);
    } else {
        loadAndPlayAll();
    }
});
</script>

