<style>
    .swiper-slide.swiper-slide-active video {
        height: 500px;
    }

    .swiper-slide video {
        height: 400px;
        width: 100%;
        object-fit: cover;
    }

    .swiper-wrapper {
        display: flex;
        align-items: center;
    }

    .swiper-container.swiper-container-horizontal {
        cursor: grab;
    }

    .swiper-button-next_1,
    .swiper-button-prev_1 {
        display: none;
    }

    .active-slide video {
        animation: playVideo 1s forwards;
    }

    @keyframes playVideo {
        to {
            opacity: 1;
            pointer-events: auto;
        }
    }

    @media (max-width: 768px) {
        .swiper-button-next_1,
        .swiper-button-prev_1 {
            display: block;
        }

        .swiper-button-next_1 svg {
            position: absolute;
            bottom: 0;
            height: 53px;
            position: absolute;
            z-index: 99;
            fill: white;
            right: -4px;
            top: 44%;
            background: black;
            padding: 16px 5px;
        }

        .swiper-button-prev_1 svg {
            position: absolute;
            bottom: 0;
            height: 53px;
            position: absolute;
            z-index: 99;
            fill: white;
            left: -7px;
            top: 44%;
            background: black;
            padding: 16px 5px;
        }
        .swiper-slide video {
            height: 400px;
            width: 89%;
            object-fit: cover;
            margin-left: 25px;
        }
    }
    @media (max-width: 500px) {
        .swiper-slide video {
            width: 86%;
        }
    }
    @media (max-width: 400px) {
        .swiper-slide video {
            width: 84%;
        }
    }
  @media (max-width: 380px) {
        .swiper-slide video {
            width: 80%;
          margin-left: 34px;
        }
    }
    @media (max-width: 350px) {
        .swiper-slide video {
            width: 83%;
        }
    }
    @media (max-width: 330px) {
        .swiper-slide video {
            width: 82%;
        }
    }
  @media only screen 
    and (width: 393px) 
    and (height: 852px) 
    and (-webkit-device-pixel-ratio: 3) {
    .swiper-slide video {
            width: 70%;
          margin-left: 34px;
        }
    }
  /* 1284×2778 pixels at 460ppi */
@media only screen 
    and (width: 430px) 
    and (height: 932px) 
    and (-webkit-device-pixel-ratio: 3) {
  .swiper-slide video {
            width: 70%;
          margin-left: 34px;
        }
    }
</style>

